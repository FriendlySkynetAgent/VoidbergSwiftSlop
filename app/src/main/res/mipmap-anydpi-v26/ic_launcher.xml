<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon (API 26+).
  Placed in res/mipmap-anydpi-v26/ so it takes priority over any
  legacy bitmap mipmaps for devices that support adaptive icons.

  Layers:
    background  — solid #557DF5 blue (matches Fluxer brand blue)
    foreground  — white icon shape (safe-zone: 24–84 within 108dp canvas)
    monochrome  — same shape in black; system applies wallpaper tint (API 33+)
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_monochrome" />
</adaptive-icon>
