<?xml version="1.0" encoding="utf-8"?>
<!--
  Round variant — identical to ic_launcher.xml.
  Launchers that use android:roundIcon apply a guaranteed circular mask,
  so the adaptive icon here is exactly the same — the background
  becomes a full-bleed circle and the foreground stays centred.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_monochrome" />
</adaptive-icon>
